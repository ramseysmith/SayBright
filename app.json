{
  "expo": {
    "name": "SayBright",
    "slug": "saybright",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "saybright",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5A623"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@bacons/apple-targets",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8327362355420246~5390186376",
          "iosAppId": "ca-app-pub-8327362355420246~5390186376"
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "This allows SayBright to show you more relevant content and support the free version of the app."
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.saybright.app",
      "buildNumber": "1",
      "entitlements": {
        "com.apple.security.application-groups": ["group.com.saybright.app"]
      },
      "infoPlist": {
        "NSUserTrackingUsageDescription": "This allows SayBright to show you more relevant content and support the free version of the app.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5A623"
      },
      "package": "com.saybright.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f9330c2a-1001-462b-a165-aca2816dd8e5"
      }
    }
  }
}
